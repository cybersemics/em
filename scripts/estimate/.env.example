# LIMIT=10 PAGE=1 DRY_RUN=true yarn backfill
# PAGE sets the 1-based Everhour task page to start from (default 1).
# DRY_RUN defaults to false; set DRY_RUN=true to preview without calling the model or writing to Everhour.
# DRY_RUN_AI / DRY_RUN_EVERHOUR override DRY_RUN for the individual stages.
# API Token can be refreshed at https://app.everhour.com/#/account/profile
EVERHOUR_API_KEY=
EVERHOUR_PROJECT_ID=
# OpenAI API key used for the estimation inference call.
OPENAI_API_KEY=
