# LIMIT=10 PAGE=1 DRY_RUN=true yarn backfill
# PAGE sets the 1-based Everhour task page to start from (default 1).
# DRY_RUN defaults to false; set DRY_RUN=true to preview without calling the model or writing to Everhour.
# DRY_RUN_AI / DRY_RUN_EVERHOUR override DRY_RUN for the individual stages.
# API Token can be refreshed at https://app.everhour.com/#/account/profile
EVERHOUR_API_KEY=
EVERHOUR_PROJECT_ID=
# OpenAI API key used for the estimation inference call.
OPENAI_API_KEY=
# Inference tuning (all optional; defaults shown):
# ESTIMATE_MODEL=gpt-5.6-terra          # OpenAI model used for estimation.
# ESTIMATE_VOTES=5                       # Self-consistency samples drawn per estimate (Chat Completions `n`).
# ESTIMATE_REASONING_EFFORT=            # Reasoning effort for reasoning models (none|low|medium|high|xhigh|max). Sent only when set.
# ESTIMATE_TEMPERATURE=                  # Sent only when set; most reasoning models reject a non-default temperature.
# Retrieval few-shot (kNN) tuning (all optional; defaults shown):
# ESTIMATE_EMBEDDING_MODEL=text-embedding-3-small  # OpenAI embeddings model for kNN sample retrieval.
# ESTIMATE_NEIGHBORS=8                   # Number of nearest samples injected into the prompt. Falls back to all samples when embeddings are unavailable.
# Confidence gate tuning (all optional; defaults shown). Trips (flags for human review) when ANY signal is uncertain:
# ESTIMATE_GATE_MIN_AGREEMENT=0.5        # Minimum vote agreement (0-1); below this trips the gate.
# ESTIMATE_GATE_MAX_DISPERSION=0.5       # Maximum neighbor-category dispersion (0-1); above this trips the gate.
# ESTIMATE_GATE_MIN_CONFIDENCE=medium    # Minimum model self-confidence (low|medium|high); below this trips the gate.
